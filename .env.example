# TruthLens Server Deployment — API Key Configuration
# Copy this file to .env and set your keys.
# When these env vars are set, the corresponding keys are:
#   - Read from the environment at startup (not from settings.json)
#   - NOT viewable in the web UI (shown as "configured via environment")
#   - NOT saved to settings.json on disk
#
# LLM API Keys
# SEARCH_LLM_API_KEY=sk-or-your-key-here
# INTEGRATION_LLM_API_KEY=sk-or-your-key-here
#
# Search Engine API Keys (only configure the one you use)
# TAVILY_API_KEY=tvly-your-key-here
# BRAVE_API_KEY=BSA-your-key-here
# SERPAPI_API_KEY=your-key-here
# SEARXNG_BASE_URL=https://searxng.your-instance.com
