# ============================================================
# Vision Lens (AI资讯透视镜) — 环境变量配置
# 复制此文件为 .env 并填入你的 API Key
# ============================================================

# --- LLM 提供商 (三选一) ---
# 支持: deepseek / anthropic / openai
LLM_PROVIDER=deepseek

# 方式1: DeepSeek (推荐 — 便宜、中文能力强)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
# DEEPSEEK_MODEL=deepseek-chat    # 默认模型，可选 deepseek-reasoner

# 方式2: Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# 方式3: OpenAI 或其他兼容接口
# OPENAI_API_KEY=sk-your-openai-key-here
# LLM_BASE_URL=https://api.openai.com/v1   # 如用第三方代理在这里改

# --- 搜索 API (可选，不配也能用模拟数据) ---
# TAVILY_API_KEY=tvly-your-key-here
